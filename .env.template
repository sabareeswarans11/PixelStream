# Copy to .env and fill in values before running
# cp .env.template .env

# Kafka / Redpanda
KAFKA_BOOTSTRAP=localhost:19092

# Inference
DEFAULT_MODEL=yolov11n          # yolov11n | rtdetr-l
INFERENCE_DEVICE=cpu            # always cpu on Intel Mac — AMD Radeon not supported by PyTorch

# Frame Producer
VIDEO_SOURCE=data/sample.mp4
TARGET_FPS=5

# Dashboard API
API_HOST=0.0.0.0
API_PORT=8000

# Delta Lake
DELTA_PATH=data/detections
